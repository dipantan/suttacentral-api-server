      "root_name": "Pahānasutta",
      "translated_name": null,
      "acronym": "SN 35.24",
      "blurb": "The “all” consisting of the six interior and exterior sense fields should be given up.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
