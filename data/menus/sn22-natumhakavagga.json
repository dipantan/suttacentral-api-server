      "uid": "sn22.33",
      "root_name": "Natumhākasutta",
      "translated_name": null,
      "acronym": "SN 22.33",
      "blurb": "Let go of what is not yours: the five aggregates. You wouldn’t be upset if someone took the grass and sticks from the monastery grounds, so why worry over the aggregates?",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
