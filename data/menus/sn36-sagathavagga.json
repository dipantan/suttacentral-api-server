    {
      "uid": "sn36.1",
      "root_name": "Samādhisutta",
      "translated_name": "Immersion ",
      "acronym": "SN 36.1",
      "blurb": "There are three feelings, and a meditator practicing immersion can understand them.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn36.2",
      "root_name": "Sukhasutta",
      "translated_name": null,
      "acronym": "SN 36.2",
      "blurb": "There are three feelings, and all of them are suffering.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn36.3",
      "root_name": "Pahānasutta",
      "translated_name": null,
      "acronym": "SN 36.3",
      "blurb": "One should give up desire for pleasant feeling, aversion for painful feeling, and ignorance regarding neutral feeling.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn36.4",
      "root_name": "Pātālasutta",
      "translated_name": null,
      "acronym": "SN 36.4",
      "blurb": "Ordinary people think the ocean is a bottomless abyss; but really, it is the three feelings.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn36.5",
      "root_name": "Daṭṭhabbasutta",
      "translated_name": null,
      "acronym": "SN 36.5",
      "blurb": "See pleasant feeling as painful, painful feeling as a dart, and neutral feeling as impermanent.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
      "uid": "sn36.6",
      "root_name": "Sallasutta",
      "translated_name": null,
      "acronym": "SN 36.6",
      "blurb": "Both ordinary and awakened people experience the three feelings. The difference is that when an ordinary person is stricken with feeling, they react, creating more suffering, whereas an awakened person responds with equanimity.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 4
    },
    {
      "uid": "sn36.7",
      "root_name": "Paṭhamagelaññasutta",
      "translated_name": null,
      "acronym": "SN 36.7",
      "blurb": "A mendicant should await their death mindful and aware. They should bear the feelings of approaching death with wisdom and equanimity.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
