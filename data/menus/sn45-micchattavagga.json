      "root_name": "Dutiyaasappurisasutta",
      "translated_name": null,
      "acronym": "SN 45.26",
      "blurb": "A bad person practices wrong eightfold path, and a worse person has wrong knowledge and wrong liberation, too; a good person is the opposite.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
