    {
      "uid": "sn45.24",
      "root_name": "Dutiyapaṭipadāsutta",
      "translated_name": null,
      "acronym": "SN 45.24",
      "blurb": "Regardless of whether one is a lay person or a renunciate, the Buddha praises the right way, not the wrong way. The wrong eightfold path is the wrong way; the right eightfold path is the right way.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
      "uid": "sn45.25",
      "root_name": "Paṭhamaasappurisasutta",
      "translated_name": null,
      "acronym": "SN 45.25",
      "blurb": "A bad person practices wrong eightfold path; a good person practices the right eightfold path.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
