{
  "uid": "pli-tv-bu-vb-pc",
  "root_name": "Pācittiya",
  "translated_name": "Confession ",
  "node_type": "branch",
  "blurb": "The rules in this category are known in Pali as <i lang='pi' translate='no'>pācittiya</i>, “entailing confession”. There are ninety-two such rules for the monks, seventy of which are shared with the nuns. This is the largest class of rules in the Monastic Code. These rules, together with all the other rules apart from those entailing expulsion and suspension, are classed as light offenses, <i lang='pi' translate='no'>lahukāpatti</i>. For light offenses there is no penalty apart from confession.",
  "acronym": null,
  "root_lang_iso": "pli",
  "root_lang_name": "Pāli",
  "child_range": null,
  "yellow_brick_road": true,
