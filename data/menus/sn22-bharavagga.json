  "children": [
    {
      "uid": "sn22.22",
      "root_name": "Bhārasutta",
      "translated_name": null,
      "acronym": "SN 22.22",
      "blurb": "The aggregates are the burden, a person carries that burden, craving takes up the burden, and letting go puts down the burden.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn22.23",
      "root_name": "Pariññasutta",
      "translated_name": null,
      "acronym": "SN 22.23",
      "blurb": "The aggregates are to be fully understood, and the full understanding is the ending of defilements.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn22.24",
      "root_name": "Abhijānasutta",
      "translated_name": null,
      "acronym": "SN 22.24",
      "blurb": "Only by directly knowing the aggregates can one end suffering.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
      "uid": "sn22.25",
      "root_name": "Chandarāgasutta",
      "translated_name": null,
      "acronym": "SN 22.25",
      "blurb": "By letting go desire, the aggregates come to an end.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
      "uid": "sn22.26",
      "root_name": "Assādasutta",
      "translated_name": null,
      "acronym": "SN 22.26",
      "blurb": "Before his awakening, the Buddha investigated the aggregates in terms of their gratification, drawback, and escape.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn22.27",
      "root_name": "Dutiyaassādasutta",
      "translated_name": null,
      "acronym": "SN 22.27",
      "blurb": "When the Buddha fully knew the gratification, drawback, and escape regarding the five aggregates he became awakened.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn22.28",
      "root_name": "Tatiyaassādasutta",
      "translated_name": null,
      "acronym": "SN 22.28",
      "blurb": "Beings are attached to the five aggregates due to gratification, repelled due to drawbacks, and find escape because there is an escape.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
      "uid": "sn22.29",
      "root_name": "Abhinandanasutta",
      "translated_name": null,
      "acronym": "SN 22.29",
      "blurb": "If you enjoy the aggregates, you enjoy suffering.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn22.30",
      "root_name": "Uppādasutta",
      "translated_name": null,
      "acronym": "SN 22.30",
      "blurb": "The arising of the aggregates is the arising of suffering.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
      "uid": "sn22.31",
      "root_name": "Aghamūlasutta",
      "translated_name": null,
      "acronym": "SN 22.31",
      "blurb": "The aggregates are misery, desire for them is the root of misery.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn22.32",
      "root_name": "Pabhaṅgusutta",
      "translated_name": null,
      "acronym": "SN 22.32",
      "blurb": "The aggregates are fragile and their passing is not fragile.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    }
  ]
}