      "root_name": "Kūṭāgārasutta",
      "translated_name": null,
      "acronym": "SN 56.44",
      "blurb": "Just as it’s impossible to climb the upper floor without building the lower floors first, it’s impossible to end suffering without penetrating the four noble truths.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
