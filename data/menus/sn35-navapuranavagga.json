    {
      "uid": "sn35.151",
      "root_name": "Antevāsikasutta",
      "translated_name": null,
      "acronym": "SN 35.151",
      "blurb": "One with no “student” and no “teacher” dwells in happiness. Here the Buddha plays with the Pali words such that “student” means “one who dwells within” and “teacher” means “one who assails”.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn35.152",
      "root_name": "Kimatthiyabrahmacariyasutta",
      "translated_name": null,
      "acronym": "SN 35.152",
      "blurb": "If anyone asks why we live the holy life, it is for the ending of suffering.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
