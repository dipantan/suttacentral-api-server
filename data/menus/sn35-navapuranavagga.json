      "uid": "sn35.146",
      "root_name": "Kammanirodhasutta",
      "translated_name": null,
      "acronym": "SN 35.146",
      "blurb": "The six interior sense fields are not yours, but are old kamma, generated by choices in past lives. This is explained in terms of the four noble truths.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 3
    },
    {
      "uid": "sn35.147",
      "root_name": "Aniccanibbānasappāyasutta",
      "translated_name": null,
      "acronym": "SN 35.147",
      "blurb": "The way suitable for realizing extinguishment is to contemplate the process of sense experience as impermanent.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 2
    },
    {
