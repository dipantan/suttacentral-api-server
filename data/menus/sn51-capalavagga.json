      "uid": "sn51.1",
      "root_name": "Apārasutta",
      "translated_name": null,
      "acronym": "SN 51.1",
      "blurb": "The four bases of psychic power lead from the near to the far shore.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.2",
      "root_name": "Viraddhasutta",
      "translated_name": null,
      "acronym": "SN 51.2",
      "blurb": "One who has neglected the four bases of psychic power has neglected the path to the end of suffering.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.3",
      "root_name": "Ariyasutta",
      "translated_name": null,
      "acronym": "SN 51.3",
      "blurb": "The four bases of psychic power are noble and emancipating.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.4",
      "root_name": "Nibbidāsutta",
      "translated_name": null,
      "acronym": "SN 51.4",
      "blurb": "The four bases of psychic power lead to dispassion.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.5",
      "root_name": "Iddhipadesasutta",
      "translated_name": null,
      "acronym": "SN 51.5",
      "blurb": "Those who have developed psychic powers in part have developed the four bases of psychic power in part.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.6",
      "root_name": "Samattasutta",
      "translated_name": null,
      "acronym": "SN 51.6",
      "blurb": "Those who have developed psychic powers in full have developed the four bases of psychic power in full.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.7",
      "root_name": "Bhikkhusutta",
      "translated_name": null,
      "acronym": "SN 51.7",
      "blurb": "Whatever mendicants realize perfection do so by developing the four bases of psychic power.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.8",
      "root_name": "Buddhasutta",
      "translated_name": null,
      "acronym": "SN 51.8",
      "blurb": "It is because of developing the four bases of psychic power that the Realized One is called a Buddha.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
      "yellow_brick_road_count": 1
    },
    {
      "uid": "sn51.9",
      "root_name": "Ñāṇasutta",
      "translated_name": null,
      "acronym": "SN 51.9",
      "blurb": "On the night of his awakening, understanding and vision came to the Buddha regarding the four bases of psychic power.",
