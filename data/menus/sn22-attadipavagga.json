      "translated_name": null,
      "acronym": "SN 22.46",
      "blurb": "Seeing the five aggregates as impermanent, etc., leads to letting go of views and ultimately to freedom.",
      "node_type": "leaf",
      "root_lang_iso": "pli",
      "root_lang_name": "Pāli",
      "child_range": null,
      "yellow_brick_road": true,
